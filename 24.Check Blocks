## 💻 Complete Code Base

```hcl
locals {
  allowed_instance_types = ["t2.micro", "t3.micro"]
}

```

```hcl
data "aws_vpc" "my-default-vpc" {
  default = true
}

# Fetching the list of active/healthy Availability Zones in the region
data "aws_availability_zones" "boy_available" {
  state = "available"
}

resource "aws_subnet" "my-subnet" {
  vpc_id            = data.aws_vpc.my-default-vpc.id
  count             = 2
  # cidr_block        = "172.31.128.0/24"
  cidr_block        = "172.31.${128+count.index}.0/24"
  #availability_zone = var.az_type
  #availability_zone = "ap-south-1b"
  availability_zone = "ap-south-1a"


  lifecycle {
    # Postcondition block to dynamically test configuration state post-apply
    postcondition {
      #condition     = self.availability_zone == "ap-south-1b"
      #condition     = contains(data.aws_availability_zones.boy_available.names, self.availability_zone)
      #condition      = self.availability_zone == "ap-south-1c"
      condition     = contains(data.aws_availability_zones.boy_available.names, self.availability_zone)
      error_message = "We can't launch subnet ${self.availability_zone} due to flood.Only ap-south-1c az is available"
    }
  }
  
  tags = {
    Name = "My post condition subnet-${count.index}"
  }
}

check "checking_if_subnet_is_available_in_multi_azs" {
  assert {
    condition=length(distinct([for q in aws_subnet.my-subnet : q.availability_zone])) > 1
    error_message=<<-EOT
      You are deploying all subnets within the same AZ.
      Please consider distributing them across AZs for higher availability.Every thing is deployed
      in ${aws_subnet.my-subnet[0].availability_zone}
      EOT
  }
}

```

```hcl
resource "aws_instance" "my_instan" {
  ami           = data.aws_ami.own_ami_ubuntu_IND.id
  instance_type = var.instance_type
  
  tags = {
    #Name        = "city_life"
    Name        = "village_life"
    #cost_centre = "marketing" # If you remove this line, the check below will catch it and show the error
    #cost_centre = "World fund"
  }
}

check "tag_check_value" {
  assert {
    condition     = aws_instance.my_instan.tags.Name == "city_life"
    error_message = "Check tag section. Current tag is '${try(aws_instance.my_instan.tags.Name, "none")}'. Ideal should be city_life."
  }
}

check "tag_check_key" {
  assert {
    # Returns true if the key exists; false (failing the check) if it is missing
    #condition     = contains(keys(aws_instance.my_instan.tags), "cost_centre")
    condition = can(aws_instance.my_instan.tags["cost_centre"])
    error_message = "The required tag key 'cost_centre' is missing from this resource."
  }
}

# Dynamically fetching the latest official Ubuntu 22.04 LTS AMI mapping
data "aws_ami" "own_ami_ubuntu_IND" {
  most_recent = true
  owners      = ["099720109477"] # Canonical official owner ID
  provider    = aws.ubuntu_IND   # Mapping to explicit regional provider alias

  filter {
    name   = "name"
    values = ["ubuntu/images/hvm-ssd/ubuntu-jammy-22.04-amd64-server-*"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }
}

```

```hcl
terraform {
  required_providers {
    # Specifying provider requirements and constraints
    aws = {
      source  = "hashicorp/aws"
      version = ">= 6.42.0"
    }

    random = {
      source  = "hashicorp/random"
      version = "3.8.1"
    }
  }
}

# Regional AWS provider config initialized with an alias block
provider "aws" {
  region = "ap-south-1"
  alias  = "ubuntu_IND"
}

```

```hcl
variable "instance_type" {
  type    = string
  default = "t3.micro"
  #default = "t3.microq"
}

# The target availability zone parameter for the subnet deployment
variable "az_type" {
  type    = string
  default = "ap-south-1b"
  # default = "ap-forest-1b"
}
