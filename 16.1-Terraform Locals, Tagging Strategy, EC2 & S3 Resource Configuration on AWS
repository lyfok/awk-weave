# Terraform Locals, Tagging Strategy, EC2 & S3 Resource Configuration on AWS

In this task, I worked on improving my Terraform code by introducing reusable **locals**, implementing a centralized **tagging strategy**, and deploying AWS resources using cleaner and more maintainable Infrastructure as Code practices.

The main goal of this implementation was:

* Avoid hardcoded values
* Reuse common configurations
* Apply standard tags across resources
* Improve Terraform code readability and scalability

---

# Terraform Configuration

```hcl
variable "vol_siz" {
  type    = number
  default = 30

}

variable "vol_typ" {
  type    = string
  default = "gp3"

}

variable "insta_deta" {
  type    = string
  default = "t3.micro"

}

variable "additional_tags" {
  type = map(string)

  default = {
    app = "state_Highway"
  }

}

terraform {

  required_providers {

    aws = {
      source  = "hashicorp/aws"
      version = "6.41.0"
    }

    random = {
      source  = "hashicorp/random"
      version = "3.8.1"
    }

  }

}

# Creating a random integer value
# Used for generating a unique S3 bucket name

resource "random_integer" "any_integer" {

  min = 100
  max = 50000

}

# Defining reusable local values

locals {

  project       = "own learning terraform project"
  project_owner = "DevOps guy"
  cost_center   = 30
  managed_by    = "awk"

}

# Creating a common local object
# This object will be reused across resources for tagging

locals {

  project_details = {

    project       = local.project
    project_owner = local.project_owner
    cost_center   = local.cost_center
    managed_by    = local.managed_by

  }

}

# Creating S3 bucket using random integer
# Applying common tags using local object

resource "aws_s3_bucket" "own_bucket" {

  bucket = "${local.managed_by}-own-random-bucket-${random_integer.any_integer.id}" #local+custom

  tags = local.project_details

}

# Create an EC2 instance using the AMI and variable configuration

resource "aws_instance" "compute" {

  ami           = data.aws_ami.own_ami_ubuntu_IND.id
  instance_type = var.insta_deta

  root_block_device {

    delete_on_termination = true
    volume_size           = var.vol_siz
    volume_type           = var.vol_typ

  }

  # Merging common project tags
  # with additional custom tags

  tags = merge(local.project_details, var.additional_tags,{Name=local.project},{shift="day"}) #local+custom

}
```

