### 🔹 Provider Configuration

```hcl
provider "aws" {
  region = "ap-south-1" #aws resource creation location
}
```

---

### 🔹 Required Providers

```hcl
terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "6.41.0"
    }

    random = {
      source  = "hashicorp/random"
      version = "3.8.1"
    }
  }
}
```

---

### 🔹 Random Integer for Unique Bucket Name

```hcl
resource "random_integer" "own_random_int" {
  min = 1
  max = 5000
}
```

👉 Used to generate a unique S3 bucket name.

---

### 🔹 S3 Bucket Creation

```hcl
resource "aws_s3_bucket" "own_s3_static_website" {
  bucket = "own-terra-static-site-${random_integer.own_random_int.result}"
}
```

---

### 🔹 Public Access Block Configuration

```hcl
resource "aws_s3_bucket_public_access_block" "own_static_site_block" {
  bucket                  = aws_s3_bucket.own_s3_static_website.id
  block_public_acls       = false
  block_public_policy     = false
  ignore_public_acls      = false
  restrict_public_buckets = false
}
```

👉 Allows public access for static website hosting.

---

### 🔹 Bucket Policy

```hcl
resource "aws_s3_bucket_policy" "own_static_site_policy" {
  bucket = aws_s3_bucket.own_s3_static_website.id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid       = "PublicReadGetObject"
        Effect    = "Allow"
        Principal = "*"
        Action    = "s3:GetObject"
        Resource  = "${aws_s3_bucket.own_s3_static_website.arn}/*"
      }
    ]
  })
}
```

👉 Grants public read access to all objects.

---

### 🔹 Static Website Configuration

```hcl
resource "aws_s3_bucket_website_configuration" "own_static_site_conf" {
  bucket = aws_s3_bucket.own_s3_static_website.id

  index_document {
    suffix = "index.html"
  }

  error_document {
    key = "error.html"
  }
}
```

---

### 🔹 Upload HTML Files via Terraform

```hcl
resource "aws_s3_object" "own_object_index" {
  bucket       = aws_s3_bucket.own_s3_static_website.id
  key          = "index.html"
  source       = "build/index.html"
  content_type = "text/html"
}

resource "aws_s3_object" "own_object_error" {
  bucket       = aws_s3_bucket.own_s3_static_website.id
  key          = "error.html"
  source       = "build/error.html"
  content_type = "text/html"
}
```

---

### 🔹 Output

```hcl
output "use_the_below_website_endpoint" {
  value = aws_s3_bucket_website_configuration.own_static_site_conf.website_endpoint
}
```

👉 Displays the S3 website URL after deployment.

