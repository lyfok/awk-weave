data "aws_ami" "own_ami_ubuntu_IND" {
  most_recent = true
  owners      = ["099720109477"] # Canonical Official

  filter {
    name   = "name"
    values = ["ubuntu/images/hvm-ssd/ubuntu-jammy-22.04-amd64-server-*"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }
}


resource "aws_instance" "own_ubuntu_instance" {
  ami= data.aws_ami.own_ami_ubuntu_IND.id
  instance_type = "t3.micro"
  subnet_id= aws_subnet.own_service_subnet_details["subnet_1"].id

  tags={
    Name="Own_manual_subnet_attached"
  }
}

```

