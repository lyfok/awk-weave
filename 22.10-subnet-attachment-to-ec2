## Root Configurations

### `terra.tf`

Defines provider configurations, setting tight guardrails for minimum compatible infrastructure provider requirements alongside specific AWS localization configurations.

```hcl
terraform {
  required_providers {
    # Telling Terraform which providers to download and use
    aws = {
      source  = "hashicorp/aws"
      version = ">= 6.42.0"
    }

    random = {
      source  = "hashicorp/random"
      version = "3.8.1"
    }
  }
}

# Configuring the AWS region
provider "aws" {
  region = "ap-south-1"
  alias  = "ubuntu_IND"
}

```

### `own_terra_network_module.tf`

Instantiates the underlying core network resource definitions, handling values explicitly declared for network limits, subnet declarations, and custom targeting flags.

```hcl
module "highway_plus_vpc" {
  source = "./serviceroad" # Pointing to the folder where our resource code lives

  # Passing the VPC IP block and tags down to the module
  highway_vpc_details = {
    vpc_cidr_highway = "10.0.0.0/16"
    tags = {
      Name = "Highway_service_vpc"
    }
  }

  # Defining the subnets I want created. The module will loop through these.
  all_sub_details = {
    subnet_1 = {
      cidr_block_highway = "10.0.1.0/24"
    }
    subnet_2 = {
      cidr_block_highway = "10.0.2.0/24"
      public_test_key_word = true
    }
  }
}

```

### `own_module.tf`

Surfaces high-level values and properties produced directly by the underlying module execution back up to the execution CLI.

```hcl
output "module_public_subnet_display_doll" {
  value = module.highway_plus_vpc.public_subnet_display
}

output "module_private_subnet_display" {
  value = module.highway_plus_vpc.private_subnet_display
}

output "module_vpc_id_details" {
  value = module.highway_plus_vpc.own_vpc_id_details
}



output "module_subnet_id_show_for_ec2_attach" {
  value=module.highway_plus_vpc.manual_subnet_display
}

## Submodule Configurations: `serviceroad/`

### `serviceroad/variable.tf`

Enforces object typing structure models and structural map expectations. Includes a built-in input verification validation framework processing input validation checks utilizing standard network functions.

```hcl
variable "all_sub_details" {
  type = map(object({
    cidr_block_highway = string
    tags               = optional(map(string))
    public_test_key_word        = optional(bool,false)
  }))
  validation{
    condition=alltrue([for x in var.all_sub_details: can(cidrnetmask(x.cidr_block_highway))])
    error_message = "Provided highway cidr is invalid."

  }
  
}
variable "highway_vpc_details" {
  type = object({
    vpc_cidr_highway = string
    tags             = map(string)
  })
}

```

### `serviceroad/local.tf`

Uses local processing blocks to transform complex collection structures dynamically. Subnets evaluate here conditionally according to the state of the matching `public_test_key_word` flag.

```hcl
locals {
  public_subnet_check = {
    for x, y in var.all_sub_details : x => {
      own_subnet_id = aws_subnet.own_service_subnet_details[x].id
      own_availability_zone = aws_subnet.own_service_subnet_details[x].availability_zone
    } if y.public_test_key_word
  }
}

locals {
  private_subnet_check = {
    for q, w in var.all_sub_details : q => {
      own_subnet_id = aws_subnet.own_service_subnet_details[q].id
      own_availability_zone = aws_subnet.own_service_subnet_details[q].availability_zone
    } if !w.public_test_key_word
  }

}

locals {
  manual_subnet_show=aws_subnet.own_service_subnet_details["subnet_1"].id
}

```

### `serviceroad/resources.tf`

Defines operational infrastructure items, applying looping maps dynamically, referencing computed conditions for edge gateway attachments, pulling image state details via targeted query filters, and handling server deployments.

```hcl
resource "aws_vpc" "own_vpc" {
  cidr_block = var.highway_vpc_details.vpc_cidr_highway
  tags={
    Name="own_highway_vpc"
  }
  
}

resource "aws_subnet" "own_service_subnet_details" {
  for_each= var.all_sub_details
  vpc_id = aws_vpc.own_vpc.id
  cidr_block = each.value.cidr_block_highway
  tags={
    Name=each.key
  }
  
}

resource "aws_internet_gateway" "own_gw" {
  vpc_id = aws_vpc.own_vpc.id
  count= length(local.public_subnet_check) > 0 ? 1:0

  tags = {
    Name = "own_highway_igw"
  }
}

resource "aws_route_table" "pub_rtb" {
  vpc_id = aws_vpc.own_vpc.id

  count= length(local.public_subnet_check) > 0 ? 1:0



  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.own_gw[0].id ##############why zero think
  }
}

resource "aws_route_table_association" "public_asso" {
  for_each = local.public_subnet_check

  subnet_id      = aws_subnet.own_service_subnet_details[each.key].id
  route_table_id = aws_route_table.pub_rtb[0].id
}



