## The Code

### 1. Provider Configuration (`highway/tera.tf`)

```hcl
terraform {
  required_providers {
    # Telling Terraform which providers to download and use
    aws = {
      source  = "hashicorp/aws"
      version = ">= 6.42.0"
    }

    random = {
      source  = "hashicorp/random"
      version = "3.8.1"
    }
  }
}

# Configuring the AWS region
provider "aws" {
  region = "ap-south-1"
  alias  = "ubuntu_IND"
}

```

### 2. Calling the Module (`highway/own_network_module.tf`)

```hcl
module "highway_plus_vpc" {
  source = "./serviceroad" # Pointing to the folder where our resource code lives

  # Passing the VPC IP block and tags down to the module
  highway_vpc_details = {
    vpc_cidr_highway = "10.0.0.0/16"
    tags = {
      Name = "Highway_service_vpc"
    }
  }

  # Defining the subnets I want created. The module will loop through these.
  all_sub_details = {
    subnet_1 = {
      cidr_block_highway = "10.0.1.0/24"
    }
    subnet_2 = {
      cidr_block_highway = "10.0.2.0/24"
    }
  }
}

```

### 3. Module Variables (`highway/serviceroad/variabl.tf`)

```hcl
variable "all_sub_details" {
  type = map(object({
    cidr_block_highway = string
    tags               = optional(map(string)) # Optional so I don't have to provide it if I don't need it
  }))

  # Checks that the CIDR blocks provided are actually valid IP ranges before running
  validation {
    condition     = alltrue([for x in var.all_sub_details : can(cidrnetmask(x.cidr_block_highway))])
    error_message = "Provided highway cidr is invalid."
  }
}

variable "highway_vpc_details" {
  type = object({
    vpc_cidr_highway = string
    tags             = map(string)
  })
}

```

### 4. Module Resources (`highway/serviceroad/resource.tf`)

```hcl
# Creating the VPC
resource "aws_vpc" "own_vpc" {
  cidr_block = var.highway_vpc_details.vpc_cidr_highway
  tags = {
    Name = "own_highway_vpc"
  }
}

# Creating the Subnets dynamically
resource "aws_subnet" "own_service_subnet_details" {
  for_each   = var.all_sub_details # Loop through every subnet defined in the root module call
  vpc_id     = aws_vpc.own_vpc.id # Attach it directly to the VPC we made above
  cidr_block = each.value.cidr_block_highway

  # This names the subnet tag "subnet_1", "subnet_2", etc. automatically based on the map keys
  tags = {
    Name = each.key
  }
}
