### 1. Root Configurations

#### `project1/terra.tf`

This file configures our required providers and targets the Mumbai (`ap-south-1`) region.

```hcl
terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 6.42.0"
    }

    random = {
      source  = "hashicorp/random"
      version = "3.8.1"
    }
  }
}

provider "aws" {
  region = "ap-south-1"
  alias  = "ubuntu_IND"
}

```

#### `project1/mai.tf`

The root file calls the custom `vpc-own` module and passes configuration for the VPC and a static map containing two subnets.

```hcl
module "Dev_vpc" {
  source = "./modules/vpc-own"
  own_vpc_details = {
    config1_vpc_cidr = "10.0.0.0/16"
    Name             = "own_vpc_module "
  }

  multi_sub_details = {
    "subnet_1" = {
      cidr_block_own = "10.0.0.0/24"
    }
    "subnet_2" = {
      cidr_block_own = "10.0.1.0/24"
    }
  }
}

```

