## Service Road Module (`/serviceroad`)

### `variable.tf`

Defines configuration schemas alongside rigorous network address validation patterns.

```hcl
variable "all_sub_details" {
  type = map(object({
    cidr_block_highway = string
    tags               = optional(map(string))
    public_test_key_word        = optional(bool,false)
  }))
  validation{
    condition=alltrue([for x in var.all_sub_details: can(cidrnetmask(x.cidr_block_highway))])
    error_message = "Provided highway cidr is invalid."

  }
  
}
variable "highway_vpc_details" {
  type = object({
    vpc_cidr_highway = string
    tags             = map(string)
  })
}

```

### `local.tf`

Handles calculations and structural parsing to distinguish between desired public and private resources based on flag configurations.

```hcl
locals {
  public_subnet_check = {
    for x, y in var.all_sub_details : x => y if y.public_test_key_word
  }

  private_subnet_check = {
    for x, y in var.all_sub_details : x => y if !y.public_test_key_word
  }
}

```

### `resources.tf`

The main provisioning configuration logic for setting up AWS infrastructure components.

```hcl
resource "aws_vpc" "own_vpc" {
  cidr_block = var.highway_vpc_details.vpc_cidr_highway
  tags={
    Name="own_highway_vpc"
  }
  
}

resource "aws_subnet" "own_service_subnet_details" {
  for_each= var.all_sub_details
  vpc_id = aws_vpc.own_vpc.id
  cidr_block = each.value.cidr_block_highway
  tags={
    Name=each.key
  }
  
}

resource "aws_internet_gateway" "own_gw" {
  vpc_id = aws_vpc.own_vpc.id
  count= length(local.public_subnet_check) > 0 ? 1:0

  tags = {
    Name = "own_highway_igw"
  }
}

resource "aws_route_table" "pub_rtb" {
  vpc_id = aws_vpc.own_vpc.id

  count= length(local.public_subnet_check) > 0 ? 1:0



  route {
    cidr_block = "0.0.0.0/0"
    gateway_id = aws_internet_gateway.own_gw[0].id ##############why zero think
  }
}

resource "aws_route_table_association" "public_asso" {
  for_each = local.public_subnet_check

  subnet_id      = aws_subnet.own_service_subnet_details[each.key].id
  route_table_id = aws_route_table.pub_rtb[0].id
}

```

